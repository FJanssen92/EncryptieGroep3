@model EncryptieGroep3.Models.AesEncryptionViewModel

@{
    ViewData["Title"] = "AES Encryption & Decryption";
}

<h1>Part 2: AES Encryption & Decryption</h1>

<div class="alert alert-info">
    <p class="mb-1">"AES" is symmetrische encryptie.</p>
    <p class="mb-1">Gebruik bij voorkeur "CBC" met "PKCS7" padding.</p>
    <p class="mb-1">"ECB" is minder veilig en wordt vooral gebruikt om het verschil in modi te tonen.</p>
    <p class="mb-0">De "IV" moet 16 bytes lang zijn en wordt hier ingevoerd in "Base64".</p>
</div>

<div class="card info-card mb-3">
    <div class="card-body">
        <h5 class="card-title mb-2">AES in het kort</h5>
        <p class="mb-1">AES is symmetrische encryptie: dezelfde key wordt gebruikt om te encrypten en decrypten.</p>
        <p class="mb-1"><strong>Wanneer gebruiken?</strong> Voor snelle bescherming van tekst en bestanden.</p>
        <p class="mb-0"><strong>Best practices:</strong> gebruik CBC + PKCS7, bewaar key/IV veilig, en deel de key nooit via een onveilig kanaal.</p>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <ul class="mb-0">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">Encrypt</h3>

                <form asp-action="Part2Encrypt" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="PlainText" class="form-label">Plaintext</label>
                        <textarea asp-for="PlainText" class="form-control" rows="6"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">AES Key (Base64)</label>
                        <input asp-for="Key" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="IV" class="form-label">IV (Base64)</label>
                        <input asp-for="IV" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedMode" class="form-label">Cipher Mode <span data-bs-toggle="tooltip" title="CBC is aanbevolen. ECB is minder veilig.">ⓘ</span></label>
                        <select asp-for="SelectedMode" class="form-select">
                            <option value="CBC">CBC</option>
                            <option value="ECB">ECB</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedPadding" class="form-label">Padding <span data-bs-toggle="tooltip" title="PKCS7 werkt in de meeste scenario's het best.">ⓘ</span></label>
                        <select asp-for="SelectedPadding" class="form-select">
                            <option value="PKCS7">PKCS7</option>
                            <option value="Zeros">Zeros</option>
                            <option value="None">None</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">Encrypt</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">Decrypt</h3>

                <form asp-action="Part2Decrypt" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="CipherText" class="form-label">Ciphertext (Base64)</label>
                        <textarea asp-for="CipherText" class="form-control" rows="6"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Key" class="form-label">AES Key (Base64)</label>
                        <input asp-for="Key" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="IV" class="form-label">IV (Base64)</label>
                        <input asp-for="IV" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedMode" class="form-label">Cipher Mode</label>
                        <select asp-for="SelectedMode" class="form-select">
                            <option value="CBC">CBC</option>
                            <option value="ECB">ECB</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SelectedPadding" class="form-label">Padding</label>
                        <select asp-for="SelectedPadding" class="form-select">
                            <option value="PKCS7">PKCS7</option>
                            <option value="Zeros">Zeros</option>
                            <option value="None">None</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success">Decrypt</button>
                </form>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Result))
{
    <div class="card mt-4 shadow-sm">
        <div class="card-body">
            <h3 class="card-title">Resultaat</h3>
            <textarea class="form-control" rows="6" readonly>@Model.Result</textarea>
        </div>
    </div>
}
<form asp-action="Part2Clear" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-outline-secondary">Clear / Reset</button>
</form>

<hr />
<hr />

<div class="alert alert-info">
    <p class="mb-1">File Encryption gebruikt dezelfde AES instellingen als text encryptie.</p>
    <p class="mb-1">Gebruik bij voorkeur "CBC" met "PKCS7" padding.</p>
    <p class="mb-0">Na encryptie of decryptie wordt het resultaat automatisch als bestand gedownload.</p>
</div>

<h2>File Encryption & Decryption</h2>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">Encrypt File</h3>

                <form asp-action="Part2EncryptFile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Bestand uploaden</label>
                        <input type="file" name="file" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">AES Key (Base64)</label>
                        <input type="text" name="key" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">IV (Base64)</label>
                        <input type="text" name="iv" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cipher Mode</label>
                        <select name="selectedMode" class="form-select">
                            <option value="CBC">CBC</option>
                            <option value="ECB">ECB</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Padding</label>
                        <select name="selectedPadding" class="form-select">
                            <option value="PKCS7">PKCS7</option>
                            <option value="Zeros">Zeros</option>
                            <option value="None">None</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">Encrypt File</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title">Decrypt File</h3>

                <form asp-action="Part2DecryptFile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Encrypted bestand uploaden</label>
                        <input type="file" name="file" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">AES Key (Base64)</label>
                        <input type="text" name="key" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">IV (Base64)</label>
                        <input type="text" name="iv" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Cipher Mode</label>
                        <select name="selectedMode" class="form-select">
                            <option value="CBC">CBC</option>
                            <option value="ECB">ECB</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Padding</label>
                        <select name="selectedPadding" class="form-select">
                            <option value="PKCS7">PKCS7</option>
                            <option value="Zeros">Zeros</option>
                            <option value="None">None</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success">Decrypt File</button>
                </form>
            </div>
        </div>
    </div>
</div>